@model DevOpsProject.Models.ContactFormModel
@{
    ViewData["Title"] = "Contact Us";
}

<!-- Contact Hero -->
<section class="contact-hero">
    <div class="container">
        <span class="section-label" data-aos="fade-down">Reach Out</span>
        <h1 class="fw-bold mb-3" data-aos="fade-up" data-aos-delay="100">Contact Us</h1>
        <p data-aos="fade-up" data-aos-delay="200" style="color:#8fa8c0; max-width:520px;">
            We'd love to hear from you. Whether it's a bulk order, service enquiry or general question — our Akure team is ready to help.
        </p>
    </div>
</section>

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="container mt-4" data-aos="fade-up">
        <div class="alert-success-custom d-flex align-items-center gap-3">
            <i class="fa fa-check-circle fa-2x text-gold"></i>
            <div>
                <strong>Message sent!</strong> Thank you for reaching out. Our team will get back to you within 24 hours.
            </div>
        </div>
    </div>
}

<!-- Contact Section -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="row g-5">

            <!-- Details -->
            <div class="col-lg-5" data-aos="fade-right">
                <h4 class="fw-bold mb-4" style="color:var(--navy);">Get In Touch</h4>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-map-marker-alt"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy); font-size:0.9rem;">Our Location</h6>
                        <p class="text-muted small mb-0">Opposite Police College, Itaogbolu,<br/>Akure North LGA, Ondo State, Nigeria.</p>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-phone-alt"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy); font-size:0.9rem;">Phone Number</h6>
                        <a href="tel:+2347079536875" class="text-muted small text-decoration-none">+234 707 953 6875</a>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fab fa-whatsapp"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy); font-size:0.9rem;">WhatsApp</h6>
                        <a href="https://wa.me/2347079536875" target="_blank" class="text-muted small text-decoration-none">+234 707 953 6875 (Chat with us)</a>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-envelope"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy); font-size:0.9rem;">Email Address</h6>
                        <a href="mailto:energyasmas@gmail.com" class="text-muted small text-decoration-none">energyasmas&#64;gmail.com</a>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-clock"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy); font-size:0.9rem;">Business Hours</h6>
                        <p class="text-muted small mb-0">Mon – Sat: 7:00 AM – 8:00 PM<br/>Sunday: 9:00 AM – 5:00 PM</p>
                    </div>
                </div>

                <!-- Social -->
                <div class="mt-4">
                    <p class="small fw-semibold mb-2" style="color:var(--navy);">Follow Us</p>
                    <div class="d-flex gap-2">
                        <a href="#" class="social-link" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-link" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-link" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="social-link" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="col-lg-7" data-aos="fade-left">
                <div class="contact-form-card">
                    <h4 class="fw-bold mb-1" style="color:var(--navy);">Send Us a Message</h4>
                    <p class="text-muted small mb-4">We respond within 24 hours on business days.</p>

                    <form asp-action="ContactSubmit" asp-controller="Home" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Full Name</label>
                                <input asp-for="FullName" class="form-control" placeholder="Your full name" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+234 xxx xxx xxxx" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Service of Interest</label>
                                <select asp-for="ServiceInterest" class="form-select">
                                    <option value="">Select a service...</option>
                                    <option>Oil & Gas Exploration</option>
                                    <option>Petroleum Supply & Distribution</option>
                                    <option>Car Wash</option>
                                    <option>Lubrication Center</option>
                                    <option>Mini Mart</option>
                                    <option>General Enquiry</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Message</label>
                                <textarea asp-for="Message" class="form-control" rows="5" placeholder="Tell us how we can help you..." required></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-gold w-100 py-2 fw-semibold">
                                    <i class="fa fa-paper-plane me-2"></i>Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Google Maps -->
<section class="map-container">
    <iframe
        src="https://maps.google.com/maps?q=Itaogbolu,+Akure+North,+Ondo+State,+Nigeria&output=embed&z=14"
        allowfullscreen=""
        loading="lazy"
        title="ASMAS Energy Location">
    </iframe>
</section>
