@{
    ViewData["Title"] = "Contact Us";
}

<!-- Contact Hero -->
<section class="contact-hero">
    <div class="container">
        <p class="text-warning small text-uppercase fw-semibold mb-2">Reach Out</p>
        <h1 class="fw-bold mb-3">Contact Us</h1>
        <p class="text-secondary" style="max-width:540px;">We'd love to hear from you. Whether you have a question about our services, a bulk order enquiry, or just want to say hello — our team in Akure is ready to help.</p>
    </div>
</section>

<!-- Contact Section -->
<section class="py-5" style="background:#f5f5f0;">
    <div class="container">
        <div class="row g-5">

            <!-- Contact Details -->
            <div class="col-lg-5">
                <h4 class="fw-bold mb-4" style="color:var(--navy);">Get In Touch</h4>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-map-marker-alt"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy);">Our Location</h6>
                        <p class="text-muted small mb-0">Opposite Police College, Itaogbolu,<br/>Akure North Local Government,<br/>Ondo State, Nigeria.</p>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-phone-alt"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy);">Phone Number</h6>
                        <p class="text-muted small mb-0">
                            <a href="tel:+2347079536875" class="text-decoration-none text-muted">+234 707 953 6875</a>
                        </p>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-envelope"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy);">Email Address</h6>
                        <p class="text-muted small mb-0">
                            <a href="mailto:energyasmas@gmail.com" class="text-decoration-none text-muted">energyasmas&#64;gmail.com</a>
                        </p>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="contact-icon"><i class="fa fa-clock"></i></div>
                    <div>
                        <h6 class="fw-semibold mb-1" style="color:var(--navy);">Business Hours</h6>
                        <p class="text-muted small mb-0">
                            Monday – Saturday: 7:00 AM – 8:00 PM<br/>
                            Sunday: 9:00 AM – 5:00 PM
                        </p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="contact-form-card">
                    <h4 class="fw-bold mb-1" style="color:var(--navy);">Send Us a Message</h4>
                    <p class="text-muted small mb-4">Fill out the form below and we'll get back to you as soon as possible.</p>

                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Full Name</label>
                                <input type="text" class="form-control" placeholder="Your full name" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Phone Number</label>
                                <input type="tel" class="form-control" placeholder="+234 xxx xxx xxxx" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Email Address</label>
                                <input type="email" class="form-control" placeholder="your@email.com" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Service of Interest</label>
                                <select class="form-select">
                                    <option value="">Select a service...</option>
                                    <option>Oil & Gas Exploration</option>
                                    <option>Petroleum Supply & Distribution</option>
                                    <option>Car Wash</option>
                                    <option>Lubrication Center</option>
                                    <option>Mini Mart</option>
                                    <option>General Enquiry</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Message</label>
                                <textarea class="form-control" rows="5" placeholder="Tell us how we can help you..."></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-gold w-100 py-2">
                                    <i class="fa fa-paper-plane me-2"></i>Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Map placeholder -->
<section>
    <div style="background:#e0e0d8; height:280px; display:flex; align-items:center; justify-content:center; flex-direction:column; color:#667;">
        <i class="fa fa-map-marker-alt fa-3x mb-3 text-warning"></i>
        <p class="fw-semibold mb-1">ASMAS Energy &mdash; Itaogbolu, Akure North, Ondo State</p>
        <a href="https://maps.google.com/?q=Itaogbolu+Akure+North+Ondo+State+Nigeria" target="_blank" class="btn btn-sm btn-gold mt-2">
            <i class="fa fa-directions me-1"></i>Get Directions
        </a>
    </div>
</section>
