@{
    ViewData["Title"] = "About Us";
}

<!-- About Hero -->
<section class="about-hero">
    <div class="container">
        <p class="text-warning small text-uppercase fw-semibold mb-2">Who We Are</p>
        <h1 class="fw-bold mb-3">About ASMAS Energy</h1>
        <p class="text-secondary" style="max-width:580px;">A proudly Nigerian-owned energy company delivering quality petroleum products and integrated services from the heart of Akure, Ondo State.</p>
    </div>
</section>

<!-- Company Story -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="section-title">Our Story</h2>
                <p class="text-muted mt-4">
                    ASMAS Energy was founded with a clear vision: to provide Akure and the wider Ondo State community with reliable, affordable, and high-quality energy products and services. Rooted in the heart of Itaogbolu, our company has grown from a petroleum distribution business into a full-service energy and lifestyle hub.
                </p>
                <p class="text-muted">
                    We understand the energy needs of Nigerian households, businesses, and motorists. That's why we've built our service portfolio to address those needs comprehensively — from sourcing and distributing petroleum products to offering vehicle care and everyday convenience through our mini mart.
                </p>
                <p class="text-muted">
                    As a 100% Nigerian-owned enterprise, we take pride in contributing to the local economy, creating jobs, and empowering our community in Akure North Local Government, Ondo State.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="row g-3 text-center">
                    <div class="col-6">
                        <div class="p-4 rounded" style="background:#f5f5f0;">
                            <h2 class="fw-bold" style="color:var(--gold);">5+</h2>
                            <p class="text-muted small mb-0">Years of Service</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded" style="background:#f5f5f0;">
                            <h2 class="fw-bold" style="color:var(--gold);">5</h2>
                            <p class="text-muted small mb-0">Service Lines</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded" style="background:#f5f5f0;">
                            <h2 class="fw-bold" style="color:var(--gold);">100%</h2>
                            <p class="text-muted small mb-0">Nigerian Owned</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded" style="background:#f5f5f0;">
                            <h2 class="fw-bold" style="color:var(--gold);">Ondo</h2>
                            <p class="text-muted small mb-0">State Based</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-5" style="background:#f5f5f0;">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="p-4 bg-white rounded shadow-sm h-100">
                    <div class="service-icon mb-3"><i class="fa fa-bullseye"></i></div>
                    <h4 class="fw-bold" style="color:var(--navy);">Our Mission</h4>
                    <p class="text-muted mt-3">
                        To provide accessible, quality energy products and services to individuals and businesses across Ondo State — with integrity, reliability, and a commitment to customer satisfaction at the core of everything we do.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-4 bg-white rounded shadow-sm h-100">
                    <div class="service-icon mb-3"><i class="fa fa-eye"></i></div>
                    <h4 class="fw-bold" style="color:var(--navy);">Our Vision</h4>
                    <p class="text-muted mt-3">
                        To become the leading integrated energy and lifestyle service company in Southwest Nigeria, recognized for our professionalism, community impact, and unwavering commitment to quality.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title centered mx-auto">Our Core Values</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="value-card h-100">
                    <h6><i class="fa fa-shield-alt me-2 text-warning"></i>Integrity</h6>
                    <p class="small text-muted mb-0">We conduct our business with transparency and honesty. Our customers trust us because we deliver on every promise.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card h-100">
                    <h6><i class="fa fa-star me-2 text-warning"></i>Quality</h6>
                    <p class="small text-muted mb-0">From our petroleum products to our car wash and mini mart, we maintain the highest standards of quality in all services.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card h-100">
                    <h6><i class="fa fa-users me-2 text-warning"></i>Community</h6>
                    <p class="small text-muted mb-0">We are deeply rooted in Akure. We create local jobs, support our neighbours, and invest in the growth of Ondo State.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="value-card h-100">
                    <h6><i class="fa fa-leaf me-2 text-warning"></i>Sustainability</h6>
                    <p class="small text-muted mb-0">We are committed to responsible energy practices that protect the environment while meeting the needs of today.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:var(--navy);">
    <div class="container text-center text-white">
        <h2 class="fw-bold mb-3">Let's Build Together</h2>
        <p class="text-secondary mb-4">Whether you're a business or individual, ASMAS Energy has a service for you.</p>
        <a asp-controller="Home" asp-action="Contact" class="btn btn-gold btn-lg me-3">Contact Us</a>
        <a asp-controller="Home" asp-action="Services" class="btn btn-outline-gold btn-lg">View Services</a>
    </div>
</section>
