@{
    ViewData["Title"] = "About Us";
}

<!-- About Hero -->
<section class="about-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="section-label" data-aos="fade-down">Who We Are</span>
                <h1 class="fw-bold mb-3" data-aos="fade-up" data-aos-delay="100">About ASMAS Energy</h1>
                <p data-aos="fade-up" data-aos-delay="200" style="color:#8fa8c0; max-width:540px;">
                    A proudly Nigerian-owned energy company delivering quality petroleum products and integrated services from the heart of Akure, Ondo State.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Company Story -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <span class="section-label">Our Story</span>
                <h2 class="section-title">Built on Trust, Powered by Purpose</h2>
                <p class="text-muted mt-4">
                    ASMAS Energy was founded with a clear vision: to provide Akure and the wider Ondo State community with reliable, affordable, and high-quality energy products and services. Rooted in Itaogbolu, we have grown from a petroleum distribution business into a full-service energy and lifestyle hub.
                </p>
                <p class="text-muted">
                    We understand the energy needs of Nigerian households, businesses, and motorists — which is why we've built our service portfolio to address those needs comprehensively. From sourcing and distributing petroleum products, to vehicle care and everyday convenience through our mini mart.
                </p>
                <p class="text-muted">
                    As a 100% Nigerian-owned enterprise, we take pride in contributing to the local economy, creating employment, and empowering our community in Akure North Local Government, Ondo State.
                </p>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="row g-3 text-center">
                    <div class="col-6">
                        <div class="p-4 rounded-custom" style="background:var(--light-bg);">
                            <h2 class="fw-bold text-gold mb-1">5+</h2>
                            <p class="text-muted small mb-0">Years of Service</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-custom" style="background:var(--light-bg);">
                            <h2 class="fw-bold text-gold mb-1">500+</h2>
                            <p class="text-muted small mb-0">Customers Served</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-custom" style="background:var(--light-bg);">
                            <h2 class="fw-bold text-gold mb-1">5</h2>
                            <p class="text-muted small mb-0">Service Lines</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-custom" style="background:var(--light-bg);">
                            <h2 class="fw-bold text-gold mb-1">100%</h2>
                            <p class="text-muted small mb-0">Nigerian Owned</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-label">Our Direction</span>
            <h2 class="section-title centered mx-auto">Mission & Vision</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6" data-aos="fade-up" data-aos-delay="0">
                <div class="p-4 bg-white rounded-custom shadow-sm h-100">
                    <div class="service-icon mb-3"><i class="fa fa-bullseye"></i></div>
                    <h4 class="fw-bold" style="color:var(--navy);">Our Mission</h4>
                    <p class="text-muted mt-3">
                        To provide accessible, quality energy products and services to individuals and businesses across Ondo State — with integrity, reliability, and a commitment to customer satisfaction at the core of everything we do.
                    </p>
                </div>
            </div>
            <div class="col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="p-4 bg-white rounded-custom shadow-sm h-100">
                    <div class="service-icon mb-3"><i class="fa fa-eye"></i></div>
                    <h4 class="fw-bold" style="color:var(--navy);">Our Vision</h4>
                    <p class="text-muted mt-3">
                        To become the leading integrated energy and lifestyle service company in Southwest Nigeria, recognised for our professionalism, community impact, and unwavering commitment to quality products and services.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-label">What We Stand For</span>
            <h2 class="section-title centered mx-auto">Our Core Values</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="0">
                <div class="value-card h-100">
                    <h6><i class="fa fa-shield-alt me-2 text-gold"></i>Integrity</h6>
                    <p class="small text-muted mb-0">We conduct our business with full transparency and honesty. Our customers trust us because we keep every promise.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                <div class="value-card h-100">
                    <h6><i class="fa fa-star me-2 text-gold"></i>Quality</h6>
                    <p class="small text-muted mb-0">From petroleum products to car wash and mini mart, we maintain the highest standards in all services.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                <div class="value-card h-100">
                    <h6><i class="fa fa-users me-2 text-gold"></i>Community</h6>
                    <p class="small text-muted mb-0">We create local jobs, support our neighbours, and invest in the growth of Ondo State every day.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                <div class="value-card h-100">
                    <h6><i class="fa fa-leaf me-2 text-gold"></i>Sustainability</h6>
                    <p class="small text-muted mb-0">We are committed to responsible energy practices that protect the environment for future generations.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Team -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-label">The People Behind ASMAS</span>
            <h2 class="section-title centered mx-auto">Meet Our Team</h2>
            <p class="text-muted mt-3 mx-auto" style="max-width:480px;">Our experienced and dedicated team is committed to delivering the best service to every customer.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="0">
                <div class="team-card">
                    <div class="team-avatar"><i class="fa fa-user-tie"></i></div>
                    <h6>Managing Director</h6>
                    <div class="role">ASMAS Energy</div>
                    <p>Leading ASMAS Energy with a vision for growth, community impact and energy excellence across Nigeria.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                <div class="team-card">
                    <div class="team-avatar"><i class="fa fa-user"></i></div>
                    <h6>Operations Manager</h6>
                    <div class="role">Operations & Logistics</div>
                    <p>Overseeing daily operations, supply chain and service delivery to ensure consistency and quality.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                <div class="team-card">
                    <div class="team-avatar"><i class="fa fa-user"></i></div>
                    <h6>Sales Manager</h6>
                    <div class="role">Sales & Distribution</div>
                    <p>Managing client relationships and growing our petroleum distribution network across Ondo State.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                <div class="team-card">
                    <div class="team-avatar"><i class="fa fa-user"></i></div>
                    <h6>Customer Service Lead</h6>
                    <div class="role">Customer Experience</div>
                    <p>Ensuring every customer interaction is handled professionally, promptly and with care.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:var(--navy);">
    <div class="container text-center" data-aos="fade-up">
        <h2 class="fw-bold text-white mb-3">Let's Build Together</h2>
        <p class="mb-4" style="color:#8fa8c0;">Whether you're a business or individual, ASMAS Energy has a service for you.</p>
        <div class="d-flex justify-content-center flex-wrap gap-3">
            <a asp-controller="Home" asp-action="Contact" class="btn btn-gold btn-lg">Contact Us</a>
            <a asp-controller="Home" asp-action="Services" class="btn btn-outline-gold btn-lg">View Services</a>
        </div>
    </div>
</section>
