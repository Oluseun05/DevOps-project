@{
    ViewData["Title"] = "Services";
}

<!-- Services Hero -->
<section class="about-hero">
    <div class="container">
        <span class="section-label" data-aos="fade-down">What We Offer</span>
        <h1 class="fw-bold mb-3" data-aos="fade-up" data-aos-delay="100">Our Services</h1>
        <p data-aos="fade-up" data-aos-delay="200" style="color:#8fa8c0; max-width:560px;">
            From petroleum exploration to everyday convenience, ASMAS Energy delivers an integrated range of services designed to meet the energy and lifestyle needs of Ondo State.
        </p>
    </div>
</section>

<!-- Service 1: Oil & Gas Exploration -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-search-location"></i></div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-search-location"></i></div>
                    <div>
                        <span class="news-tag">Service 01</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Oil & Gas Exploration</h3>
                    </div>
                </div>
                <p class="text-muted">
                    ASMAS Energy provides professional oil and gas exploration support services, including site surveys, resource evaluation, and field assessments across the Niger Delta and Southwest Nigeria. We work with partners to identify viable energy resources while adhering to Nigerian regulatory standards set by the Department of Petroleum Resources (DPR).
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Site surveys and feasibility studies","Resource assessment and reporting","Regulatory compliance support (DPR)","Field operations coordination"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block" data-aos="fade-left" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-exploration.jpg')">
                    <div class="panel-watermark"><i class="fa fa-search-location"></i></div>
                    <div class="panel-badge"><i class="fa fa-hard-hat me-1"></i>Oil & Gas Exploration</div>
                </div>
            </div>
        </div>
        <hr class="mt-5" />
    </div>
</section>

<!-- Service 2: Petroleum Supply -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-gas-pump"></i></div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block order-lg-last" data-aos="fade-right" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-petroleum.jpg')">
                    <div class="panel-watermark"><i class="fa fa-gas-pump"></i></div>
                    <div class="panel-badge"><i class="fa fa-truck me-1"></i>Petroleum Supply & Distribution</div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-gas-pump"></i></div>
                    <div>
                        <span class="news-tag">Service 02</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Petroleum Supply & Distribution</h3>
                    </div>
                </div>
                <p class="text-muted">
                    We are a trusted supplier of quality petroleum products serving businesses, fleet operators, and individual customers in Akure and across Ondo State. Our distribution network ensures timely and reliable delivery of petrol, diesel, and kerosene at competitive prices.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Petrol (PMS) supply","Diesel (AGO) for businesses & generators","Kerosene (DPK) distribution","Bulk supply for fleet & commercial clients"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Service 3: Car Wash -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-car"></i></div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-car"></i></div>
                    <div>
                        <span class="news-tag">Service 03</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Car Wash</h3>
                    </div>
                </div>
                <p class="text-muted">
                    Our professional car wash facility at Itaogbolu, Akure North offers thorough exterior and interior cleaning services for all vehicle types. We use quality cleaning products and experienced staff to ensure your vehicle leaves spotless every time.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Full exterior body wash","Interior vacuuming and cleaning","Tyre and rim cleaning","Express wash available"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block" data-aos="fade-left" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-carwash.jpg')">
                    <div class="panel-watermark"><i class="fa fa-car"></i></div>
                    <div class="panel-badge"><i class="fa fa-tint me-1"></i>Car Wash — Itaogbolu, Akure North</div>
                </div>
            </div>
        </div>
        <hr class="mt-5" />
    </div>
</section>

<!-- Service 4: Lubrication Center -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-oil-can"></i></div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block order-lg-last" data-aos="fade-right" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-lube.jpg')">
                    <div class="panel-watermark"><i class="fa fa-oil-can"></i></div>
                    <div class="panel-badge"><i class="fa fa-cog me-1"></i>Lubrication Center</div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-oil-can"></i></div>
                    <div>
                        <span class="news-tag">Service 04</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Lubrication Center</h3>
                    </div>
                </div>
                <p class="text-muted">
                    Keep your engine in peak condition with our certified lubrication services. ASMAS Energy's lubrication center offers oil changes, filter replacements and full-service lubrication for cars, trucks, and commercial vehicles using premium-grade lubricants from trusted brands including Castrol, Shell Helix and Total Quartz.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Engine oil change (all grades)","Oil & air filter replacement","Gear oil & transmission fluid service","Brake fluid top-up"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Service 5: Mini Mart -->
