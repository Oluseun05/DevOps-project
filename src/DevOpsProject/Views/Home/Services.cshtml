    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-store"></i></div>
