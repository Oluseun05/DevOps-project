            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-store"></i></div>
                    <div>
                        <span class="news-tag">Service 05</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Mini Mart</h3>
                    </div>
                </div>
                <p class="text-muted">
                    Our on-site mini mart is stocked with a wide range of everyday essentials — perfect for customers stopping to refuel or service their vehicles. Everything you need in one convenient location at ASMAS Energy.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Soft drinks, water & beverages","Snacks, biscuits & confectionery","Groceries & household essentials","Toiletries & personal care products"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block" data-aos="fade-left" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-minimart.jpg')">
                    <div class="panel-watermark"><i class="fa fa-store"></i></div>
                    <div class="panel-badge"><i class="fa fa-shopping-basket me-1"></i>Mini Mart — ASMAS Energy</div>
                </div>
            </div>
        </div>
        <hr class="mt-5" />
    </div>
</section>

<!-- Service 6: Cooking Gas / LPG -->
<section class="py-5" style="background:var(--light-bg);">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-fire"></i></div>
            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block order-lg-last" data-aos="fade-right" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-lpg.jpg')">
                    <div class="panel-watermark"><i class="fa fa-fire"></i></div>
                    <div class="panel-badge"><i class="fa fa-fire me-1"></i>Cooking Gas / LPG</div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-fire"></i></div>
                    <div>
                        <span class="news-tag">Service 06</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Cooking Gas / LPG</h3>
                    </div>
                </div>
                <p class="text-muted">
                    ASMAS Energy supplies clean, safe, and affordable liquefied petroleum gas (LPG) for households and businesses across Ondo State. Available in a range of cylinder sizes, our cooking gas service ensures your kitchen and commercial operations never run out of fuel. We also offer safe doorstep delivery and cylinder exchange.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"3kg, 5kg & 12.5kg cylinders available","New cylinder sales & refilling service","Safe home and business delivery","Commercial & bulk LPG supply"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
                                <i class="fa fa-check-circle text-gold"></i><span>@item</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Service 7: Air / Water -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5" data-aos="fade-up">
            <div class="col-lg-1 d-none d-lg-flex justify-content-center">
                <div class="service-icon" style="width:72px;height:72px;font-size:1.8rem;"><i class="fa fa-wind"></i></div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="service-icon d-lg-none"><i class="fa fa-wind"></i></div>
                    <div>
                        <span class="news-tag">Service 07</span>
                        <h3 class="fw-bold mb-0" style="color:var(--navy);">Air / Water</h3>
                    </div>
                </div>
                <p class="text-muted">
                    Keep your vehicle safe and roadworthy with our free air and water station available to all customers on our forecourt. Whether you need to inflate your tyres to the correct pressure or top up your radiator coolant, our service point is always accessible and maintained.
                </p>
                <div class="row g-2 mt-2">
                    @foreach (var item in new[]{"Free tyre inflation for all customers","Digital pressure gauge for accuracy","Clean water point on the forecourt","Available during all business hours"}) {
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 small text-muted">
