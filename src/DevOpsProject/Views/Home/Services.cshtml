            </div>
            <div class="col-12 col-lg-5 d-none d-lg-block" data-aos="fade-left" data-aos-delay="100">
                <div class="service-visual img-panel" style="background-image:url('/images/service-airwater.jpg')">
                    <div class="panel-watermark"><i class="fa fa-wind"></i></div>
                    <div class="panel-badge"><i class="fa fa-tachometer-alt me-1"></i>Air & Water — Free for All Customers</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:var(--navy);">
    <div class="container text-center" data-aos="fade-up">
        <h2 class="fw-bold text-white mb-3">Interested in Any of Our Services?</h2>
        <p class="mb-4" style="color:#8fa8c0;">Get in touch and our team will be happy to assist you right away.</p>
        <div class="d-flex justify-content-center flex-wrap gap-3">
            <a asp-controller="Home" asp-action="Contact" class="btn btn-gold btn-lg">
                <i class="fa fa-envelope me-2"></i>Contact Us
            </a>
            <a href="https://wa.me/2347079536875" target="_blank" class="btn btn-lg" style="background:#25d366;color:#fff;border:none;">
                <i class="fab fa-whatsapp me-2"></i>WhatsApp Us
            </a>
        </div>
    </div>
</section>
