<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASMAS Energy</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/asmas.css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-asmas sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                ASMAS <span>ENERGY</span>
            </a>
            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer-asmas">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="brand mb-2">ASMAS ENERGY</div>
                    <p class="small">Powering progress across Nigeria with reliable energy solutions, quality petroleum products, and exceptional service from our base in Akure, Ondo State.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-1"><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="mb-1"><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li class="mb-1"><a asp-controller="Home" asp-action="Services">Services</a></li>
                        <li class="mb-1"><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Contact Us</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><i class="fa fa-map-marker-alt me-2 text-warning"></i>Opp. Police College, Itaogbolu, Akure North, Ondo State</li>
                        <li class="mb-2"><i class="fa fa-phone me-2 text-warning"></i>+234 707 953 6875</li>
                        <li class="mb-2"><i class="fa fa-envelope me-2 text-warning"></i>energyasmas&#64;gmail.com</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom text-center">
                &copy; @DateTime.Now.Year ASMAS Energy Limited. All rights reserved. &mdash; Akure, Ondo State, Nigeria.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
